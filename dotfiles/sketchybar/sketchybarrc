#!/bin/bash

# Catppuccin Mocha Color Palette
export BASE=0xff1e1e2e
export MANTLE=0xff181825
export CRUST=0xff11111b
export TEXT=0xffcdd6f4
export SUBTEXT0=0xffa6adc8
export SUBTEXT1=0xffbac2de
export SURFACE0=0xff313244
export SURFACE1=0xff45475a
export SURFACE2=0xff585b70
export OVERLAY0=0xff6c7086
export OVERLAY1=0xff7f849c
export ROSEWATER=0xfff5e0dc
export FLAMINGO=0xfff2cdcd
export PINK=0xfff5c2e7
export MAUVE=0xffcba6f7
export RED=0xfff38ba8
export MAROON=0xffeba0ac
export PEACH=0xfffab387
export YELLOW=0xfff9e2af
export GREEN=0xffa6e3a1
export TEAL=0xff94e2d5
export SKY=0xff89dceb
export SAPPHIRE=0xff74c7ec
export BLUE=0xff89b4fa
export LAVENDER=0xffb4befe

# General bar appearance
sketchybar --bar \
    height=40 \
    blur_radius=30 \
    position=top \
    padding_left=10 \
    padding_right=10 \
    margin=0 \
    corner_radius=0 \
    color=$BASE \
    shadow=off \
    sticky=on \
    notch_width=0

# Default item settings
sketchybar --default \
    updates=when_shown \
    icon.font="Hack Nerd Font:Bold:17.0" \
    icon.color=$TEXT \
    icon.padding_left=8 \
    icon.padding_right=4 \
    label.font="Hack Nerd Font:Bold:14.0" \
    label.color=$TEXT \
    label.padding_left=4 \
    label.padding_right=8 \
    background.color=$SURFACE0 \
    background.corner_radius=12 \
    background.height=28 \
    background.padding_left=4 \
    background.padding_right=4

##### LEFT SIDE #####

# Apple logo
sketchybar --add item apple.logo left \
    --set apple.logo \
        icon= \
        icon.font="SF Pro:Black:16.0" \
        icon.color=$BLUE \
        icon.padding_left=6 \
        icon.padding_right=6 \
        label.drawing=off \
        background.padding_left=4 \
        background.padding_right=4 \
        background.color=$MANTLE \
        popup.background.border_width=2 \
        popup.background.corner_radius=10 \
        popup.background.border_color=$SURFACE0 \
        popup.background.color=$MANTLE \
        click_script="sketchybar --set \$NAME popup.drawing=toggle"

sketchybar --add item apple.prefs popup.apple.logo \
    --set apple.prefs \
        icon= \
        label="Preferences" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="open -a 'System Settings'; sketchybar --set apple.logo popup.drawing=off"

sketchybar --add item apple.activity popup.apple.logo \
    --set apple.activity \
        icon= \
        label="Activity" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="open -a 'Activity Monitor'; sketchybar --set apple.logo popup.drawing=off"

sketchybar --add item apple.lock popup.apple.logo \
    --set apple.lock \
        icon= \
        label="Lock Screen" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="osascript -e 'tell application \"System Events\" to keystroke \"q\" using {control down, command down}'; sketchybar --set apple.logo popup.drawing=off"

sketchybar --add item apple.nix_config popup.apple.logo \
    --set apple.nix_config \
        icon= \
        label="Nix Config" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="/Users/julienmartel/.config/nix/dotfiles/sketchybar/plugins/nix_open.sh; sketchybar --set apple.logo popup.drawing=off"

sketchybar --add item apple.rebuild popup.apple.logo \
    --set apple.rebuild \
        icon=󰑓 \
        label="Rebuild System" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="/Users/julienmartel/.config/nix/dotfiles/sketchybar/plugins/launch_rebuild.sh"

sketchybar --add item apple.reload popup.apple.logo \
    --set apple.reload \
        icon= \
        label="Reload SketchyBar" \
        icon.padding_left=10 \
        label.padding_right=10 \
        background.height=30 \
        background.padding_left=0 \
        background.padding_right=0 \
        background.color=0x00000000 \
        background.drawing=off \
        click_script="sketchybar --reload; sketchybar --set apple.logo popup.drawing=off"

# Spaces - All AeroSpace workspaces
sketchybar --add event aerospace_workspace_change
WORKSPACES=("1" "2" "3" "4" "C" "T" "N" "S" "B" "G" "L" "F" "M")

for workspace in "${WORKSPACES[@]}"
do
    sketchybar --add item space.$workspace left \
        --set space.$workspace \
            icon="$workspace" \
            icon.drawing=on \
            icon.padding_left=10 \
            icon.padding_right=10 \
            icon.highlight_color=$YELLOW \
            background.color=$SURFACE0 \
            background.drawing=on \
            background.corner_radius=12 \
            background.height=28 \
            label.drawing=off \
            script="$HOME/.config/sketchybar/plugins/space.sh" \
            click_script="aerospace workspace $workspace" \
        --subscribe space.$workspace aerospace_workspace_change
done

# Front app name
sketchybar --add item front_app left \
    --set front_app \
        icon.drawing=off \
        background.color=$LAVENDER \
        label.color=$BASE \
        label.font="Hack Nerd Font:Bold:14.0" \
        label.padding_left=8 \
        label.padding_right=8 \
        script="$HOME/.config/sketchybar/plugins/front_app.sh" \
    --subscribe front_app front_app_switched

##### RIGHT SIDE #####

# Clock (moved to far right)
sketchybar --add item clock right \
    --set clock \
        update_freq=10 \
        icon= \
        icon.color=$PINK \
        background.color=$MANTLE \
        background.padding_left=8 \
        background.padding_right=8 \
        script="$HOME/.config/sketchybar/plugins/clock.sh" \
        click_script="open -a 'Notion Calendar'"

# Media
sketchybar --add item media right \
    --set media \
        icon= \
        icon.color=$PINK \
        background.color=$SURFACE0 \
        background.padding_left=8 \
        background.padding_right=8 \
        label.max_chars=25 \
        scroll_texts=on \
        script="$HOME/.config/sketchybar/plugins/media.sh" \
    --subscribe media media_change

# Battery
sketchybar --add item battery right \
    --set battery \
        icon.color=$GREEN \
        background.color=$SURFACE0 \
        update_freq=30 \
        script="$HOME/.config/sketchybar/plugins/battery.sh" \
        click_script="open -a 'System Settings' 'x-apple.systempreferences:com.apple.preference.battery'" \
    --subscribe battery system_woke power_source_change

# WiFi
sketchybar --add item wifi right \
    --set wifi \
        icon=󰖩 \
        label.drawing=off \
        icon.color=$TEAL \
        background.color=$SURFACE0 \
        icon.padding_left=10 \
        icon.padding_right=10 \
        script="$HOME/.config/sketchybar/plugins/wifi.sh" \
        click_script="open -a 'System Settings' 'x-apple.systempreferences:com.apple.wifi-settings-extension'" \
        update_freq=10

# Elgato Light
sketchybar --add item elgato right \
    --set elgato \
        update_freq=5 \
        script="/Users/julienmartel/.config/nix/dotfiles/sketchybar/plugins/elgato.sh" \
        background.color=$SURFACE0 \
        icon.padding_left=10 \
        icon.padding_right=10 \
        click_script="/Users/julienmartel/.config/nix/dotfiles/sketchybar/plugins/elgato.sh" \
    --subscribe elgato mouse.clicked

# Harvest
sketchybar --add item harvest right \
    --set harvest \
        update_freq=3 \
        script="$HOME/.config/sketchybar/plugins/harvest.sh" \
    --subscribe harvest mouse.clicked harvest_update system_woke

##### Finalizing Setup #####

# Force all scripts to run at startup
sketchybar --update

echo "sketchybar configuration loaded.."
